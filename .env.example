# Rename this file to .env and add your Razorpay credentials.
# For email: configure an SMTP provider such as Gmail App Password, SendGrid SMTP, Mailgun SMTP, or any SMTP service.
RAZORPAY_KEY_ID=rzp_test_yourKeyId
RAZORPAY_KEY_SECRET=yourSecretKey
PORT=3000
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password
# The sender address is automatically set to SMTP_USER.
EMAIL_TO=your-email@example.com
